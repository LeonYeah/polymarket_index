APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://polymarket:polymarket@localhost:5432/polymarket
REDIS_URL=redis://localhost:6379/0

POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_BASE_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_WS_BASE_URL=wss://ws-subscriptions-clob.polymarket.com/ws

API_PROBE_TIMEOUT_SECONDS=20
API_PROBE_OUTPUT_DIR=docs/samples

MARKET_INGESTION_PAGE_LIMIT=100
MARKET_INGESTION_MAX_MARKETS=500
MARKET_INGESTION_HOLDERS_MARKET_LIMIT=25
MARKET_INGESTION_HOLDERS_LIMIT=50
MARKET_INGESTION_TARGET_CATEGORIES=Politics,Finance,Tech
MARKET_INGESTION_TOKEN_VERIFICATION_LIMIT=100

WALLET_CANDIDATE_LIMIT=500
WALLET_LEADERBOARD_LIMIT=150
WALLET_HOLDER_CANDIDATE_LIMIT=250
WALLET_ACTIVE_TRADER_LIMIT=500
WALLET_BACKFILL_WALLET_LIMIT=100
WALLET_BACKFILL_PAGE_LIMIT=100
WALLET_BACKFILL_MAX_TRADE_PAGES=10
WALLET_BACKFILL_RETRY_ATTEMPTS=3
WALLET_BACKFILL_RETRY_BASE_SECONDS=1.0

PRICE_ARCHIVE_TOKEN_LIMIT=100
PRICE_ARCHIVE_HISTORY_INTERVAL=1d
PRICE_ARCHIVE_ORDERBOOK_DEPTH_LIMIT=20
PRICE_ARCHIVE_ORDERBOOK_INTERVAL_SECONDS=30
PRICE_ARCHIVE_ORDERBOOK_CYCLES=1
PRICE_ARCHIVE_WEBSOCKET_SECONDS=30
PRICE_ARCHIVE_WEBSOCKET_EVENT_LIMIT=100
PRICE_ARCHIVE_CLV_LIMIT=1000
PRICE_ARCHIVE_CLV_REFERENCE_DELAY_SECONDS=0
PRICE_ARCHIVE_FOLLOWABILITY_SIZE=10
PRICE_ARCHIVE_FOLLOWABILITY_MAX_SPREAD_BPS=500

# Maximum cumulative open paper cost basis for one strategy/token pair, in USDC.
PAPER_MAXIMUM_TOKEN_NOTIONAL=100

# Slots within the continuous token budget reserved for strict-paper wallet trades.
PAPER_TOKEN_RESERVE=10
