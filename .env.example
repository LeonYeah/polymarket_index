APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://polymarket:polymarket@localhost:5432/polymarket
REDIS_URL=redis://localhost:6379/0

POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_BASE_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_WS_BASE_URL=wss://ws-subscriptions-clob.polymarket.com/ws

API_PROBE_TIMEOUT_SECONDS=20
API_PROBE_OUTPUT_DIR=docs/samples

MARKET_INGESTION_PAGE_LIMIT=100
MARKET_INGESTION_MAX_MARKETS=500
MARKET_INGESTION_HOLDERS_MARKET_LIMIT=25
MARKET_INGESTION_HOLDERS_LIMIT=50
MARKET_INGESTION_TARGET_CATEGORIES=Politics,Finance,Tech
MARKET_INGESTION_TOKEN_VERIFICATION_LIMIT=100
