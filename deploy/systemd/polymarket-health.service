[Unit]
Description=Check Polymarket sampling health
After=postgresql.service polymarket-sampler.service

[Service]
Type=oneshot
User=polymarket
Group=polymarket
WorkingDirectory=/opt/polymarket-wallet-tracker
EnvironmentFile=/etc/polymarket-wallet-tracker.env
ExecStart=/opt/polymarket-wallet-tracker/.venv/bin/python -m backend.scripts.check_sampling_health --max-age-seconds 300 --allow-degraded
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
