[Unit]
Description=Back up Polymarket PostgreSQL database
After=postgresql.service

[Service]
Type=oneshot
User=postgres
Group=postgres
ExecStart=/opt/polymarket-wallet-tracker/deploy/backup_postgres.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/backups/polymarket
